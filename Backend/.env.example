DEBUG=True
SECRET_KEY=django-insecure-change-this-to-a-long-random-string-in-production
JWT_SECRET_KEY=change-this-to-a-long-random-jwt-secret-in-production
PORT=8000
FRONTEND_URL=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_labs
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Google OAuth2 — Client ID from Google Cloud Console
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Gmail SMTP — use an App Password, NOT your main Gmail password
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password_here
OWNER_EMAIL=you@gmail.com

# Twilio SMS OTP — sign up free at twilio.com
# Find SID + Auth Token at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
OTP_PHONE_COUNTRY_CODE=+91

# Phone field encryption key — generate once and never change
# Run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PHONE_ENCRYPTION_KEY=rWMCb2dI4479pBuUpHqBAXiWSoSUcv7tR19Cv58S2ZQ=
